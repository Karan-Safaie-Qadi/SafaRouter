{
  "name": "safa-router",
  "version": "2.0.1",
  "description": "A professional standalone frontend router inspired by Next.js App Router — works with any framework or vanilla JS",
  "type": "module",
  "main": "src/index.js",
  "types": "safa-router.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./safa-router.d.ts"
    },
    "./core": {
      "import": "./src/core/SafaRouter.js",
      "types": "./safa-router.d.ts"
    },
    "./features/*": {
      "import": "./src/features/*.js",
      "types": "./safa-router.d.ts"
    },
    "./typed": {
      "import": "./src/typed.js",
      "types": "./safa-router.d.ts"
    },
    "./vite": {
      "import": "./src/vite-plugin.js",
      "types": "./safa-router.d.ts"
    },
    "./*": "./src/*.js"
  },
  "files": [
    "src/",
    "safa-router.d.ts"
  ],
  "scripts": {
    "start": "node dev-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "node dev-server.js",
    "lint": "echo \"Add lint tool\"",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "router",
    "frontend-router",
    "spa-router",
    "app-router",
    "nextjs-router",
    "vanilla-js",
    "client-side-routing",
    "single-page-app",
    "nested-layouts",
    "middleware",
    "dynamic-routes",
    "spa",
    "single-page-application",
    "ssr",
    "access-control",
    "middleware",
    "nested-layouts",
    "error-handling",
    "real-time",
    "hot-reload",
    "typescript"
  ],
  "author": "Karan Safaie Qadi (Karan-Safaie-Qadi)",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karan-Safaie-Qadi/SafaRouter.git"
  },
  "bugs": {
    "url": "https://github.com/Karan-Safaie-Qadi/SafaRouter/issues"
  },
  "homepage": "https://github.com/Karan-Safaie-Qadi/SafaRouter#readme",
  "devDependencies": {
    "docx": "^9.7.1",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
